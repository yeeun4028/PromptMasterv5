<Window x:Class="PromptMasterv5.Views.ScreenCaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Region" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Cursor="None"
        MouseRightButtonUp="Window_MouseRightButtonUp">
    
    <Grid>
        <!-- Semi-transparent overlay (technically almost transparent to keep hit-test visible) -->
        <Rectangle x:Name="DimOverlay" Fill="#01000000"/>
        
        <!-- Selection rectangle (drawn dynamically) -->
        <Canvas x:Name="SelectionCanvas" Background="Transparent"
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
            
            <!-- Full-screen Crosshair Guides -->
            <Line x:Name="HorizontalGuide" Stroke="#00BFFF" StrokeThickness="1" SnapsToDevicePixels="True" IsHitTestVisible="False"/>
            <Line x:Name="VerticalGuide" Stroke="#00BFFF" StrokeThickness="1" SnapsToDevicePixels="True" IsHitTestVisible="False"/>

            <!-- Loading Animation -->
            <Grid x:Name="LoadingSpinner" Width="18" Height="18" Visibility="Collapsed">
                <Grid.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate" CenterX="9" CenterY="9"/>
                </Grid.RenderTransform>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="0" To="360" Duration="0:0:1"
                                                 RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
                
                <!-- Blue Arc (Right Side extended) -->
                <Path Data="M 11,2.5 A 7,7 0 0 1 11,15.5" 
                      Stroke="#007ACC" StrokeThickness="1.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round">

                </Path>
                
                <!-- Red Arc (Left Side extended) -->
                <Path Data="M 7,15.5 A 7,7 0 0 1 7,2.5" 
                      Stroke="#DC143C" StrokeThickness="1.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round">
                </Path>

                <!-- Blue Arrow -->
                <Polygon Points="11,15.5 13.5,13 9.5,13.5" Fill="#007ACC"/>

                <!-- Red Arrow -->
                <Polygon Points="7,2.5 4.5,5 8.5,4.5" Fill="#DC143C"/>
            </Grid>

            <Rectangle x:Name="SelectionRect" 
                       Stroke="#00BFFF" 
                       StrokeThickness="1"
                       Fill="Transparent"
                       Visibility="Collapsed"/>
        </Canvas>
    </Grid>
</Window>
