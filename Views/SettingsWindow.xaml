<Window x:Class="PromptMasterv5.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PromptMasterv5.Views"
        Title="设置"
        Width="900" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewMouseRightButtonDown="Window_PreviewMouseRightButtonDown"
        Closing="Window_Closing">
    <views:SettingsView x:Name="SettingsViewContent"/>
</Window>
