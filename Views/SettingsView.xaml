<UserControl x:Class="PromptMasterv5.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:models="clr-namespace:PromptMasterv5.Models"
             xmlns:utils="clr-namespace:PromptMasterv5.Utils"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="750">
    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="AppBackground" Color="#F1F1EF"/>
        <SolidColorBrush x:Key="SidebarBackground" Color="#F7F7F7"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <Color x:Key="AccentColorValue">#4183C4</Color>
        <SolidColorBrush x:Key="AccentColor" Color="{StaticResource AccentColorValue}"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>
        <SolidColorBrush x:Key="DividerColor" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="HintBrush" Color="#999999"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E53935"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#C62828"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <utils:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- Icons -->
        <Geometry x:Key="IconShortcut">M19,3H5C3.89,3 3,3.89 3,5V19C3,20.11 3.89,21 5,21H19C20.11,21 21,20.11 21,19V5C21,3.89 20.11,3 19,3M19,19H5V5H19V19M11,17H13V15H11V17M15,17H17V15H15V17M7,17H9V15H7V17M11,13H13V11H11V13M15,13H17V11H15V13M7,13H9V11H7V13M11,9H13V7H11V9M15,9H17V7H15V9M7,9H9V7H7V9Z</Geometry>
        <Geometry x:Key="IconModel">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6M12,8A4,4 0 0,0 8,12A4,4 0 0,0 12,16A4,4 0 0,0 16,12A4,4 0 0,0 12,8Z</Geometry>
        <Geometry x:Key="IconMiniWindow">M19,13H5V11H19V13Z</Geometry>

        <!-- Tab Button Style -->
        <Style x:Key="ModernTabBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                         <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EAEAEA"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fade In Animation -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="10" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="FadeInContentStyle" TargetType="StackPanel">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColorValue}" Opacity="0.2" BlurRadius="4" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColorValue}" Opacity="0.2" BlurRadius="4" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TextLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="LinkText"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="13"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="LinkText" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerLinkButtonStyle" TargetType="Button" BasedOn="{StaticResource TextLinkButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="LinkText"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="13"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="TextDecorations" Value="Underline"/>
                                <Setter TargetName="LinkText" Property="Foreground" Value="{StaticResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="LinkText" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- Modal Overlay -->
        <Border Background="#66000000">
            <!-- Main Settings Window -->
            <Border Width="750" Height="500" Background="{StaticResource AppBackground}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="25" ShadowDepth="0"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Sidebar -->
                    <Border Background="{StaticResource SidebarBackground}" CornerRadius="12,0,0,12" BorderBrush="{StaticResource DividerColor}" BorderThickness="0,0,1,0">
                        <StackPanel Margin="15,25">
                            <!-- Tab Buttons -->
                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconShortcut}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,1,12,1"/>
                                    <TextBlock Text="快捷键" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="16" Width="16" TextAlignment="Center" Margin="0,1,12,1" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="自动化" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconModel}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,1,12,1"/>
                                    <TextBlock Text="模型" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="3">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="☁️" FontSize="16" Width="16" TextAlignment="Center" Margin="0,1,12,1" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="同步" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="4">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconMiniWindow}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,1,12,1"/>
                                    <TextBlock Text="极简窗口" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Right Content Area -->
                    <Grid Grid.Column="1" Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Close Button -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="{Binding SelectedSettingsTabName}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            <Button Command="{Binding SaveSettingsCommand}" 
                                    Content="✕" FontSize="18" Foreground="#999"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Tab Contents -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                            <Grid>
                                <!-- Tab 0: Shortcut -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <CheckBox IsChecked="{Binding Config.EnableDoubleCtrl}" Cursor="Hand">
                                            <CheckBox.Content>
                                                <TextBlock Text="双击 Ctrl 键唤醒/隐藏窗口" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="5,-1,0,0"/>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="全局唤醒热键" Style="{StaticResource FieldLabelTextStyle}"/>
                                        <TextBox Text="{Binding Config.GlobalHotkey}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 1: Automation -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="输入发送模式" Style="{StaticResource FieldLabelTextStyle}"/>

                                        <RadioButton GroupName="InputMode"
                                                     IsChecked="{Binding LocalConfig.Mode, Converter={models:EnumToBoolConverter}, ConverterParameter=SmartFocus}"
                                                     Content="智能回退模式 (推荐)"
                                                     FontSize="14" Cursor="Hand" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                                        <TextBlock Text="软件隐藏后，自动将焦点还给上一个活动的窗口 (如浏览器输入框)，然后发送内容。"
                                                   Style="{StaticResource HintTextStyle}" Margin="20,0,0,12"/>

                                        <Border Height="1" Background="{StaticResource DividerColor}" Margin="0,4,0,12"/>

                                        <RadioButton GroupName="InputMode"
                                                     IsChecked="{Binding LocalConfig.Mode, Converter={models:EnumToBoolConverter}, ConverterParameter=CoordinateClick}"
                                                     Content="坐标点击模式"
                                                     FontSize="14" Cursor="Hand" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                                        <TextBlock Text="软件隐藏后，强制点击屏幕上的指定位置来激活输入框。"
                                                   Style="{StaticResource HintTextStyle}" Margin="20,0,0,10"/>

                                        <StackPanel Margin="20,6,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LocalConfig.Mode}" Value="CoordinateClick">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="15"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="X 坐标" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding LocalConfig.ClickX}" Width="80" Style="{StaticResource ModernTextBoxStyle}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Y 坐标" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding LocalConfig.ClickY}" Width="80" Style="{StaticResource ModernTextBoxStyle}"/>
                                                </StackPanel>

                                                <Button Grid.Column="4"
                                                        Content="⏱️ 3秒后拾取"
                                                        Click="PickCoordinate_Click"
                                                        Style="{StaticResource TextLinkButtonStyle}"
                                                        VerticalAlignment="Bottom"/>
                                            </Grid>
                                            <TextBlock Text="* 点击按钮后请迅速移动鼠标到目标位置，等待3秒自动记录。"
                                                       Style="{StaticResource HintTextStyle}"
                                                       Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 2: AI Models -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="API 地址 (Base URL)" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.AiBaseUrl}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.AiApiKey}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="模型名称" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.AiModel}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock x:Name="TestStatusText"
                                                       Text=""
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       Style="{StaticResource HintTextStyle}"/>
                                             <Button Content="测试连接" Click="TestAiConnection_Click" Style="{StaticResource TextLinkButtonStyle}" Foreground="{StaticResource TextSecondary}" Margin="0,0,14,0"/>
                                             <Button Content="保存模型" Command="{Binding AddAiModelCommand}" Style="{StaticResource TextLinkButtonStyle}" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Text="已保存的模型" Style="{StaticResource FieldLabelTextStyle}" Margin="0,6,0,10"/>
                                    
                                    <ListBox ItemsSource="{Binding Config.SavedModels}"
                                             SelectedValue="{Binding Config.ActiveModelId}"
                                             SelectedValuePath="Id"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             SelectionMode="Single"
                                             SelectionChanged="AiModelList_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Chip"
                                                                    Background="#FAFAFA"
                                                                    BorderBrush="#E0E0E0"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="12,10"
                                                                    Margin="0,0,10,10"
                                                                    Width="180"
                                                                    Cursor="Hand">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="16" Height="16" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource DividerColor}" Margin="0,0,10,0" VerticalAlignment="Center">
                                                                         <Path x:Name="CheckMark" Data="M2,5 L5,8 L10,2" Stroke="{StaticResource AccentColor}" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                     <TextBlock Grid.Column="1" Text="{Binding ModelName}" FontSize="14" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                                                </Grid>
                                                                
                                                                <Border.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="删除" Command="{Binding DataContext.DeleteAiModelCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                 <Trigger Property="IsSelected" Value="True">
                                                                      <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                      <Setter TargetName="Chip" Property="Background" Value="#E0E0E0"/>
                                                                  </Trigger>
                                                                 <Trigger Property="IsMouseOver" Value="True">
                                                                     <Setter TargetName="Chip" Property="Background" Value="#EAEAEA"/>
                                                                 </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </StackPanel>

                                <!-- Tab 3: Sync -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    
                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="WebDAV 网址" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.WebDavUrl}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="账号 (邮箱)" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.UserName}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="应用密码" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <PasswordBox x:Name="WebDavPasswordBox"
                                                         PasswordChar="●"
                                                         Style="{StaticResource ModernPasswordBoxStyle}"
                                                         PasswordChanged="WebDavPasswordBox_PasswordChanged"
                                                         Loaded="WebDavPasswordBox_Loaded"/>
                                        </StackPanel>

                                        <Border Height="1" Background="{StaticResource DividerColor}" Margin="0,6,0,14"/>

                                        <Button Content="从云端强制恢复数据"
                                                Command="{Binding ShowRestoreConfirmCommand}"
                                                ToolTip="注意：此操作将使用云端数据覆盖本地所有数据"
                                                HorizontalAlignment="Left">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DangerLinkButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Border Margin="0,10,0,0"
                                                Background="#FFF7F7"
                                                BorderBrush="#F2C7C7"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="确定要覆盖吗？" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                    <Button Content="取消"
                                                            Command="{Binding CancelRestoreConfirmCommand}"
                                                            Style="{StaticResource TextLinkButtonStyle}"
                                                            Foreground="{StaticResource TextSecondary}"
                                                            Margin="14,0,0,0"/>
                                                    <Button Content="确认覆盖"
                                                            Command="{Binding ManualRestoreCommand}"
                                                            Style="{StaticResource DangerLinkButtonStyle}"
                                                            Margin="14,0,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>

                                        <TextBlock Text="恢复操作会完全覆盖本地文件，请谨慎操作。"
                                                   Margin="0,10,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Border Background="#FFFFFF"
                                                BorderBrush="{StaticResource DividerColor}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,12,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RestoreStatus}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RestoreStatus}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding RestoreStatus}"
                                                       Foreground="{Binding RestoreStatusColor}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 4: Mini Window -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <CheckBox IsChecked="{Binding LocalConfig.MiniWindowUseAi}" Cursor="Hand">
                                            <CheckBox.Content>
                                                <TextBlock Text="极简窗口默认使用 AI 查询" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="5,-1,0,0"/>
                                            </CheckBox.Content>
                                        </CheckBox>
                                        <TextBlock Text="勾选后，无需使用 &quot;ai&quot; 前缀，直接输入即可"
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="24,6,0,0"/>
                                    </StackPanel>

                                    <Border Height="1" Background="{StaticResource DividerColor}" Margin="0,4,0,14"/>

                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="回车键 (Enter) 行为" Style="{StaticResource FieldLabelTextStyle}"/>
                                        <RadioButton GroupName="MiniEnterMode"
                                                     IsChecked="{Binding LocalConfig.MiniEnterForAi}"
                                                     Content="Enter = AI 查询"
                                                     FontSize="14" Margin="0,0,0,8" Cursor="Hand" VerticalContentAlignment="Center"/>

                                        <RadioButton GroupName="MiniEnterMode"
                                                     IsChecked="{Binding LocalConfig.MiniEnterForAi, Converter={StaticResource InverseBoolConverter}}"
                                                     Content="Enter = 普通发送"
                                                     FontSize="14" Cursor="Hand" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
