<Window x:Class="PromptMasterv5.NameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重命名" Height="180" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource RegionBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="请输入新的名称" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,12"/>

        <TextBox x:Name="InputBox" 
                 Grid.Row="1"
                 Style="{StaticResource ModernTextBoxStyle}"
                 VerticalAlignment="Top"
                 Margin="0,0,0,20"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" IsCancel="True" Style="{StaticResource TextLinkButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="确定" IsDefault="True" Click="Ok_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>